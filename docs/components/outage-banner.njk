{% extends "component.njk" %}

{% from "govuk/components/tabs/macro.njk" import govukTabs %}
{% from "hmpps/components/outage-banner/macro.njk" import outageBanner %}

{% set pageTitle = 'Outage banner' %}
{% set activeSideNav = 'outage-banner' %}

{% set htmlCode %}
    {% highlight "html" %}
{{ outageBanner({ text: 'Some outage is due!'}) }}
    {% endhighlight %}
{% endset %}

{% set nunjucksCode %}
    {% highlight "njk" %}
        {% raw %}
        {% from "hmpps/components/outage-banner/macro.njk" import outageBanner %}

        {{ outageBanner({ text: 'Some outage is due!'}) }}
        {% endraw %}
    {% endhighlight %}
{% endset %}

{% block content %}
    <div class="app-example">
        {{ outageBanner({ text: 'Some outage is due!'}) }}
    </div>

    <p>This is the outage banner which is yet to be published in the moj frontend.</p>
    <h2>Research on this component</h2>
    <p><a href="https://design-patterns.service.justice.gov.uk/components/outage-banner/#overview-tab" class="govuk-link">Full documentation on this component</a></p>

    {{ govukTabs({
        items: [
            {
                label: "HTML",
                id: "html",
                panel: {
                    html: htmlCode
                }
            },
            {
                label: "Nunjucks",
                id: "nunjucks",
                panel: {
                    html: nunjucksCode
                }
            }
        ]
    }) }}

{% endblock %}
